# Sepolia RPC endpoint (Alchemy / Infura / dRPC / etc.)
SEPOLIA_RPC_URL=

# Deployer wallet — deploys MockPriceOracle, the premium token, and
# RedoubtCoverPool, then drives settleEpoch/finalize*/checkSolvency calls.
# Needs the most Sepolia ETH of the three (multiple deploys + many txs).
PRIVATE_KEY=

# Buyer wallets #2 and #3 — MIN_EPOCH_PARTICIPANTS is 3, so three distinct
# buyers are needed to actually exercise PremiumEpochSettled (not just
# PremiumEpochWithheld). PRIVATE_KEY above acts as buyer #1.
PRIVATE_KEY_2=
PRIVATE_KEY_3=

# Optional — enables `forge verify-contract` against Etherscan after deploy.
ETHERSCAN_API_KEY=
